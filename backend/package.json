{
  "name": "itsupport-backend",
  "version": "1.0.0",
  "description": "IT Support Management System — Node.js + Express API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src src/start.js",
    "start": "node src/start.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "setup": "node src/db/migrate.js && node src/db/migrate_technicians.js && node src/db/seed.js",
    "migrate:tech": "node src/db/migrate_technicians.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "crypto-js": "^4.2.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "adm-zip": "^0.5.10",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}