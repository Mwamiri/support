PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/itsupport

# JWT — change this to a long random string in production
JWT_SECRET=change_this_to_a_very_long_random_secret_key_in_production
JWT_EXPIRES_IN=7d

# AES encryption key for credentials (32 chars)
ENCRYPTION_KEY=change_this_32_char_encryption_key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
