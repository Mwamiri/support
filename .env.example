# ══════════════════════════════════════════════════════════════════════════════
# IT SUPPORT SYSTEM — Environment Configuration
# Copy this file: cp .env.example .env
# Fill in your values, then run: docker compose up -d
# ══════════════════════════════════════════════════════════════════════════════

# ── YOUR DOMAIN ───────────────────────────────────────────────────────────────
# The URL where your app will be accessible
# For local testing:  http://localhost
# For production:     https://itsupport.yourdomain.com
FRONTEND_URL=http://localhost

# API URL — usually same domain with /api path (nginx handles routing)
VITE_API_URL=http://localhost

# ── POSTGRESQL DATABASE ───────────────────────────────────────────────────────
POSTGRES_DB=itsupport
POSTGRES_USER=itsupport
POSTGRES_PASSWORD=change_this_to_a_strong_password_123

# ── SECURITY KEYS ─────────────────────────────────────────────────────────────
# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_jwt_secret_minimum_32_characters_long_please_change_me

# Encryption Key — EXACTLY 32 characters for AES-256
ENCRYPTION_KEY=change_this_32_char_key_padded_!!

# ── SERVER PORTS ──────────────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── ENVIRONMENT ───────────────────────────────────────────────────────────────
NODE_ENV=production
